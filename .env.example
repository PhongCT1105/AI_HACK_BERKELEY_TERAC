# Root env — used by the MCP servers in .mcp.json.
# Copy to .env and fill in. Get a 21st.dev Magic key at https://21st.dev/magic/console
MAGIC_21ST_API_KEY=

# App env — copy to .env.local for local dev, or set these as environment
# variables on your deployment host (e.g. Vercel project settings). Never
# commit the real values — this file only documents the keys.

# Supabase project (Settings > API in the Supabase dashboard).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret for /admin and the admin-only APIs (export, results, seed).
ADMIN_PASSWORD=

# Public base URL of this deployment (used in any absolute links).
NEXT_PUBLIC_APP_URL=

# How many labels each task should collect before /api/task stops preferring
# it. Optional — defaults to 3.
TARGET_LABELS_PER_TASK=3
